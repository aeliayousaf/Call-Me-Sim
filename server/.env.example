# ElevenLabs API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Agent ID from https://elevenlabs.io/app/agents (create a voice agent first)
ELEVENLABS_AGENT_ID=

# Server port
PORT=3001

# Hard cap on each AI call (milliseconds) — enforced server-side
MAX_CALL_DURATION_MS=30000

# Rate limits per device ID
MAX_CALLS_PER_HOUR=10
MAX_CALLS_PER_DAY=40

# How long a pending session can wait before token activation
SESSION_PENDING_TTL_MS=120000

# CORS — set to your app origin in production, or * for dev
CORS_ORIGIN=*
