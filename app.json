{
  "expo": {
    "name": "Call Me Now",
    "slug": "call-me-now",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "description": "Simulate incoming phone calls for practice. Does not place real calls.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.callmenow.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Call Me Now needs access to your contacts so you can choose who appears on the simulated incoming call screen.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#84C424",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.callmenow.app",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ],
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Call Me Now to access your contacts to pick a simulated caller."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#84C424",
          "sounds": []
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
